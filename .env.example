DJANGO_DEBUG=true
DEPLOYMENT_ENV=development
DJANGO_SECRET_KEY=replace-with-a-long-random-development-secret
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_TRUST_X_FORWARDED_PROTO=false
DJANGO_USE_X_FORWARDED_HOST=false
DATABASE_URL=postgresql://signage:local-development-only@localhost:5432/signage
DB_SSLMODE=disable
DB_HOST=
DB_PORT=5432
DB_NAME=signage
DB_USER=signage
DB_PASSWORD=
REQUIRED_APP_VERSION=0.1.0
DEVICE_OVERHEAT_CELSIUS=45
PILOT_BACKUP_ROOT=backend/backups
PILOT_BACKUP_RETENTION_DAYS=30
PILOT_BACKUP_S3_BUCKET=
DEFAULT_FROM_EMAIL=no-reply@duducar.co
SERVER_EMAIL=no-reply@duducar.co
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_TIMEOUT=10

# Production only. Use separate credentials and buckets for each environment.
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_S3_ENDPOINT_URL=

# Production device-integrity configuration. Store the JSON value in a secret
# manager; never commit the real credential.
PLAY_INTEGRITY_PROJECT_NUMBER=
PLAY_INTEGRITY_PACKAGE_NAME=com.duducar.signage
PLAY_INTEGRITY_SERVICE_ACCOUNT_JSON=
PLAY_INTEGRITY_MAX_TOKEN_AGE_SECONDS=120
DEVICE_MEDIA_CACHE_BYTES=10737418240
DEVICE_EVENT_QUEUE_BYTES=524288000
DEVICE_MIN_FREE_BYTES=2147483648
