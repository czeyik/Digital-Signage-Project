DJANGO_DEBUG=true
DEPLOYMENT_ENV=development
DJANGO_SECRET_KEY=replace-with-a-long-random-development-secret
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_TRUST_X_FORWARDED_PROTO=false
DJANGO_USE_X_FORWARDED_HOST=false
DATABASE_URL=postgresql://signage:local-development-only@localhost:5432/signage
DB_SSLMODE=disable
REQUIRED_APP_VERSION=0.1.0
DEVICE_OVERHEAT_CELSIUS=45
PILOT_BACKUP_ROOT=backend/backups
PILOT_BACKUP_RETENTION_DAYS=30
DEFAULT_FROM_EMAIL=no-reply@duducar.co
SERVER_EMAIL=no-reply@duducar.co
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_TIMEOUT=10

# Production only. Use separate credentials and buckets for each environment.
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_S3_ENDPOINT_URL=
